rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /registros/{docId} {
      allow read, write: if request.auth != null;
    }
    match /historico/{docId} {
      allow read, write: if request.auth != null;
    }
    match /eventos_uso/{docId} {
      allow read, write: if request.auth != null;
    }
    match /catalogo_custom/{docId} {
      allow read, write: if request.auth != null;
    }
    match /config/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
